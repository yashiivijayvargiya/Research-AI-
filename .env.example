# ═══════════════════════════════════════════════════════════════
# ReachAI — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LinkedIn OAuth Credentials ───────────────────────────────
# 1. Go to https://www.linkedin.com/developers/apps
# 2. Create an app (or open existing)
# 3. Go to "Products" tab → Request "Sign In with LinkedIn using OpenID Connect"
# 4. Go to "Auth" tab → Copy Client ID and Client Secret
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# ─── Base URL ─────────────────────────────────────────────────
# The full origin where your app is hosted (no trailing slash).
# This is used to construct the OAuth redirect URI:
#   {BASE_URL}/auth/linkedin/callback
#
# IMPORTANT: You MUST add this exact redirect URL in the LinkedIn
# Developer Portal → Auth tab → Redirect URLs:
#   http://localhost:3000/auth/linkedin/callback    (for local dev)
#   https://yourdomain.com/auth/linkedin/callback   (for production)
BASE_URL=http://localhost:3000

# ─── Session Secret ──────────────────────────────────────────
# For production, generate a strong random string:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=reachai-session-secret-change-me

# ─── Server Port ─────────────────────────────────────────────
PORT=3000
