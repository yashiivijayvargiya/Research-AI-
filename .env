# ═══════════════════════════════════════════════════════════════
# ReachAI — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── LinkedIn OAuth Credentials ───────────────────────────────
# Get these from https://www.linkedin.com/developers/apps → Auth tab
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Base URL ─────────────────────────────────────────────────
# CRITICAL: This MUST match the origin registered in LinkedIn Developer Portal.
# The redirect URI sent to LinkedIn will be: {BASE_URL}/auth/linkedin/callback
#
# Local development:
BASE_URL=http://localhost:3000
#
# Production example (uncomment and set your domain):
# BASE_URL=https://yourdomain.com

# ─── Session Secret ──────────────────────────────────────────
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=reachai-dev-secret-148a2df8

# ─── Server Port ─────────────────────────────────────────────
PORT=3000
